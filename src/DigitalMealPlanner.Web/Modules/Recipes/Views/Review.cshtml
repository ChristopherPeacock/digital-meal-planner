@model DigitalMealPlanner.Web.Modules.Recipes.Models.RecipeReviewViewModel
@{
    ViewData["Title"] = "Review Recipe";
    Layout = "_Layout";
}

<div class="page-header">
    <h1>Review &amp; Save</h1>
    <span class="muted" style="font-size:.8rem">GPT-4o extracted this — edit anything before saving</span>
</div>

<form method="post" action="/cookbooks/@Model.CookbookId/recipes/import/save">
    @Html.AntiForgeryToken()
    <input type="hidden" name="CookbookId"   value="@Model.CookbookId" />
    <input type="hidden" name="CookbookName" value="@Model.CookbookName" />
    @for (int img = 0; img < Model.ImagePaths.Count; img++)
    {
        <input type="hidden" name="ImagePaths[@img]" value="@Model.ImagePaths[img]" />
    }

    <div class="review-layout">

        <!-- Left: images -->
        <div class="review-image">
            <div class="lbl">📸 Screenshots (@Model.ImagePaths.Count)</div>
            <div class="image-picker">
                @for (int img = 0; img < Model.ImagePaths.Count; img++)
                {
                    <label class="image-pick-option @(img == Model.SelectedImageIndex ? "selected" : "")">
                        <input type="radio" name="SelectedImageIndex" value="@img"
                               @(img == Model.SelectedImageIndex ? "checked" : "") />
                        <img src="@Model.ImagePaths[img]" alt="Screenshot @(img + 1)" />
                        <span class="pick-badge">@(img == Model.SelectedImageIndex ? "★ Display" : "Select")</span>
                    </label>
                }
            </div>
        </div>

        <!-- Right: extracted data -->
        <div class="review-fields">

            <div class="lbl">Recipe Details</div>
            <div class="card card-body mb-2">
                <div class="form-group">
                    <label>Title</label>
                    <input name="Title" value="@Model.Title" class="form-control" required />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="Description" class="form-control">@Model.Description</textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Servings</label>
                        <input name="Servings" type="number" value="@Model.Servings" class="form-control" min="1" />
                    </div>
                    <div class="form-group">
                        <label>Cuisine</label>
                        <input name="CuisineType" value="@Model.CuisineType" class="form-control" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Prep (mins)</label>
                        <input name="PrepMinutes" type="number" value="@Model.PrepMinutes" class="form-control" min="0" />
                    </div>
                    <div class="form-group">
                        <label>Cook (mins)</label>
                        <input name="CookMinutes" type="number" value="@Model.CookMinutes" class="form-control" min="0" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Tags (comma separated)</label>
                    <input name="Tags" value="@Model.Tags" class="form-control" placeholder="e.g. high protein, quick, low carb" />
                </div>
            </div>

            <div class="lbl">Macros</div>
            <div class="macros mb-2">
                <div class="tile hi">
                    <div class="tv"><input name="CaloriesPerServing" type="number" value="@Model.CaloriesPerServing" class="tile-input" min="0" /></div>
                    <div class="tl">Kcal</div>
                </div>
                <div class="tile">
                    <div class="tv"><input name="ProteinG" type="number" value="@Model.ProteinG" class="tile-input" min="0" /></div>
                    <div class="tl">Protein</div>
                </div>
                <div class="tile">
                    <div class="tv"><input name="CarbsG" type="number" value="@Model.CarbsG" class="tile-input" min="0" /></div>
                    <div class="tl">Carbs</div>
                </div>
                <div class="tile">
                    <div class="tv"><input name="FatG" type="number" value="@Model.FatG" class="tile-input" min="0" /></div>
                    <div class="tl">Fat</div>
                </div>
                <div class="tile">
                    <div class="tv" style="font-size:.9rem;padding-top:.3rem">@(Model.PrepMinutes + Model.CookMinutes)</div>
                    <div class="tl">Mins</div>
                </div>
            </div>

            <div class="lbl">Ingredients</div>
            <div class="card card-body mb-2" id="ingredients-wrap">
                @for (int i = 0; i < Model.Ingredients.Count; i++)
                {
                    <div class="ing-row" data-index="@i">
                        <input type="hidden" name="Ingredients[@i].Category"       value="@Model.Ingredients[i].Category" />
                        <input type="hidden" name="Ingredients[@i].CaloriesPerUnit" value="@Model.Ingredients[i].CaloriesPerUnit" />
                        <div class="ing-fields">
                            <input name="Ingredients[@i].Quantity" value="@Model.Ingredients[i].Quantity" class="form-control ing-qty"  placeholder="Qty" />
                            <input name="Ingredients[@i].Unit"     value="@Model.Ingredients[i].Unit"     class="form-control ing-unit" placeholder="Unit" />
                            <input name="Ingredients[@i].Name"     value="@Model.Ingredients[i].Name"     class="form-control ing-name" placeholder="Ingredient" />
                            <button type="button" class="btn btn-danger btn-sm" onclick="removeIngredient(this)">×</button>
                        </div>
                    </div>
                }
            </div>
            <button type="button" class="btn btn-outline btn-sm mb-2" onclick="addIngredient()">+ Add Ingredient</button>

            <div class="lbl">Steps</div>
            <div class="card card-body mb-2">
                <label style="font-size:.78rem;color:var(--muted);margin-bottom:.35rem">One step per line</label>
                <textarea name="StepsRaw" class="form-control" rows="8">@Model.StepsRaw</textarea>
            </div>

            <div class="action-bar">
                <button type="submit" class="btn btn-primary">Save Recipe</button>
                <a href="/cookbooks/@Model.CookbookId/recipes/import" class="btn btn-outline">Re-upload</a>
                <a href="/cookbooks/@Model.CookbookId" class="btn btn-outline">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
let ingCount = @Model.Ingredients.Count;

function removeIngredient(btn) {
    btn.closest('.ing-row').remove();
    reindex();
}

function addIngredient() {
    const wrap = document.getElementById('ingredients-wrap');
    const i = ingCount++;
    const div = document.createElement('div');
    div.className = 'ing-row';
    div.dataset.index = i;
    div.innerHTML = `
        <input type="hidden" name="Ingredients[${i}].Category" value="other" />
        <input type="hidden" name="Ingredients[${i}].CaloriesPerUnit" value="0" />
        <div class="ing-fields">
            <input name="Ingredients[${i}].Quantity" class="form-control ing-qty"  placeholder="Qty" />
            <input name="Ingredients[${i}].Unit"     class="form-control ing-unit" placeholder="Unit" />
            <input name="Ingredients[${i}].Name"     class="form-control ing-name" placeholder="Ingredient" />
            <button type="button" class="btn btn-danger btn-sm" onclick="removeIngredient(this)">×</button>
        </div>`;
    wrap.appendChild(div);
}

function reindex() {
    document.querySelectorAll('#ingredients-wrap .ing-row').forEach((row, i) => {
        row.querySelectorAll('[name]').forEach(el => {
            el.name = el.name.replace(/\[\d+\]/, `[${i}]`);
        });
    });
}

// Image picker radio interaction
document.querySelectorAll('.image-pick-option input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', () => {
        document.querySelectorAll('.image-pick-option').forEach(opt => {
            opt.classList.remove('selected');
            opt.querySelector('.pick-badge').textContent = 'Select';
        });
        const label = radio.closest('.image-pick-option');
        label.classList.add('selected');
        label.querySelector('.pick-badge').textContent = '★ Display';
    });
});
</script>
}
