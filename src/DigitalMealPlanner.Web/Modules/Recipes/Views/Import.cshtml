@model DigitalMealPlanner.Web.Modules.Recipes.Models.RecipeImportViewModel
@{
    ViewData["Title"] = "Import Recipe";
    Layout = "_Layout";
}

<div class="page-header">
    <h1>Import Recipe</h1>
    <a href="/cookbooks/@Model.CookbookId" class="btn btn-outline btn-sm">← @Model.CookbookName</a>
</div>

<div class="import-wrap">
    <form method="post" action="/cookbooks/@Model.CookbookId/recipes/import"
          enctype="multipart/form-data" id="import-form">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div class="alert-danger mb-2">@err.ErrorMessage</div>
            }
        }

        <div id="drop-zone" class="drop-zone">
            <input type="file" id="image-input" name="Images" accept="image/jpeg,image/png,image/webp" multiple style="display:none" />
            <div id="image-previews" class="import-previews"></div>
            <div class="drop-icon">📸</div>
            <div class="drop-label">Drop your screenshots here, or click to browse</div>
            <div class="drop-sub">JPG · PNG · WEBP — multiple images supported</div>
        </div>

        <button type="submit" id="extract-btn" class="btn btn-primary" style="width:100%;margin-top:1rem" disabled>
            <span id="btn-idle">✨ Extract with AI</span>
            <span id="btn-loading" style="display:none">Analysing with GPT-4o…</span>
        </button>
    </form>
</div>

@section Scripts {
<script>
    const dropZone    = document.getElementById('drop-zone');
    const input       = document.getElementById('image-input');
    const previews    = document.getElementById('image-previews');
    const label       = document.querySelector('.drop-label');
    const extractBtn  = document.getElementById('extract-btn');
    const form        = document.getElementById('import-form');
    const btnIdle     = document.getElementById('btn-idle');
    const btnLoading  = document.getElementById('btn-loading');

    const selectedFiles = [];

    function addFiles(fileList) {
        for (const file of fileList) {
            selectedFiles.push(file);
            const reader = new FileReader();
            reader.onload = e => {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.className = 'import-thumb';
                previews.appendChild(img);
            };
            reader.readAsDataURL(file);
        }
        syncInput();
        label.textContent = `${selectedFiles.length} image${selectedFiles.length === 1 ? '' : 's'} selected`;
        extractBtn.disabled = selectedFiles.length === 0;
    }

    function syncInput() {
        const dt = new DataTransfer();
        selectedFiles.forEach(f => dt.items.add(f));
        input.files = dt.files;
    }

    dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', ()  => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop',      e  => { e.preventDefault(); dropZone.classList.remove('drag-over'); addFiles(e.dataTransfer.files); });
    dropZone.addEventListener('click',     ()  => input.click());
    input.addEventListener('change',       ()  => { addFiles(input.files); });

    form.addEventListener('submit', () => {
        btnIdle.style.display    = 'none';
        btnLoading.style.display = 'inline';
        extractBtn.disabled      = true;
    });
</script>
}
