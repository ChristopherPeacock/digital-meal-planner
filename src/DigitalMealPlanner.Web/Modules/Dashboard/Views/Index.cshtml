@model IEnumerable<Cookbook>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<div class="page-header">
    <h1>👋 Welcome back, Robyn</h1>
    <a href="/cookbooks/create" class="btn btn-primary">+ New Cookbook</a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="icon">📚</div>
        <h2>No Cookbooks Yet</h2>
        <p>Create your first cookbook and start adding recipes.</p>
        <a href="/cookbooks/create" class="btn btn-primary mt-2">Create Cookbook</a>
    </div>
}
else
{
    <div class="lbl">Recent Cookbooks</div>
    <div class="cookbook-grid">
        @foreach (var cb in Model)
        {
            <a href="/cookbooks/@cb.Id" class="cookbook-card card">
                <div class="cover">
                    @if (!string.IsNullOrEmpty(cb.CoverImagePath))
                    {
                        <img src="@cb.CoverImagePath" alt="@cb.Name" style="width:100%;height:140px;object-fit:cover;" />
                    }
                    else
                    {
                        <span>📖</span>
                    }
                </div>
                <div class="card-body">
                    <h3>@cb.Name</h3>
                    @if (!string.IsNullOrEmpty(cb.Description))
                    {
                        <p>@cb.Description</p>
                    }
                    <div class="count">@cb.Recipes.Count recipe@(cb.Recipes.Count == 1 ? "" : "s")</div>
                </div>
            </a>
        }
    </div>
}
