@model CookbookFormViewModel
@{
    ViewData["Title"] = "New Cookbook";
    Layout = "_Layout";
}

<div class="form-panel">
    <h1>New Cookbook</h1>
    <form method="post" action="/cookbooks/create" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Name">Cookbook Name</label>
            <input asp-for="Name" class="form-control" placeholder="e.g. Quick Weeknight Meals" autofocus />
            <span asp-validation-for="Name" class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description">Description (optional)</label>
            <textarea asp-for="Description" class="form-control" placeholder="What's this cookbook about?"></textarea>
        </div>

        <div class="form-group">
            <label asp-for="CoverImage">Cover Image (optional)</label>
            <input asp-for="CoverImage" type="file" class="form-control" accept="image/*" />
        </div>

        <div class="action-bar">
            <button type="submit" class="btn btn-primary">Create Cookbook</button>
            <a href="/cookbooks" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
